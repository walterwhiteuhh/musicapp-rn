{
  "name": "musicapp-rn",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli run:android",
    "ios": "node node_modules/expo/bin/cli run:ios",
    "web": "node node_modules/expo/bin/cli start --web",
    "build:web": "node node_modules/expo/bin/cli export --platform web --output-dir dist",
    "test": "node node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@netlify/functions": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.0",
    "lucide-react-native": "^1.16.0",
    "openai": "^6.39.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.18.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/node18": "^18.2.6",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~55.0.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~55.0.0",
    "expo-module-scripts": "^56.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "prettier": "^3.5.0",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/.expo/",
      "<rootDir>/.tools/"
    ]
  }
}
