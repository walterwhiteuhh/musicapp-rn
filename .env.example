EXPO_PUBLIC_SOUNDCLOUD_API_BASE_URL=https://api.soundcloud.com
EXPO_PUBLIC_USE_LIVE_SOUNDCLOUD_API=false
EXPO_PUBLIC_PROFILE_TAGS_ENDPOINT=/api/profile-tags
EXPO_PUBLIC_AI_PROFILE_TAGS_ENABLED=true

# Server-side Netlify Function configuration.
# Keep API keys in Netlify environment variables, not in client builds.
AI_PROVIDER=netlify-openai
AI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://klangfeld.netlify.app
OPENROUTER_APP_TITLE=Klangfeld
